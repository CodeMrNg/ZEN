# Core Django
# By default, the .env file overrides inherited environment variables.
# Set DJANGO_DOTENV_OVERRIDE=False only if your platform variables must take priority.
# DJANGO_DOTENV_OVERRIDE=False
DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=False
DJANGO_ALLOWED_HOSTS=zenntrading.pythonanywhere.com,www.zenntrading.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://zenntrading.pythonanywhere.com,https://www.zenntrading.pythonanywhere.com

# Database
# Option 1: full URL
DATABASE_URL=postgresql://user:password@host:5432/journal

# Option 2: discrete values
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=journal
# DB_USER=journal
# DB_PASSWORD=change-me
# DB_HOST=127.0.0.1
# DB_PORT=5432
DB_CONN_MAX_AGE=60

# Static / media
STATIC_ROOT=staticfiles
MEDIA_ROOT=media


# UI translation backend
# google_free: uses deep-translator with Google Translate and does not require an API key
# builtin: use the local translation dictionary only
APP_TRANSLATION_PROVIDER=google_free

# Security
USE_X_FORWARDED_PROTO=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
